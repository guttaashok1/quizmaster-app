{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/index.ts" },
    { "src": "/interview$", "dest": "public/interview/index.html" },
    { "src": "/interview/$", "dest": "public/interview/index.html" },
    { "src": "/interview/(.*)", "dest": "public/interview/$1" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
