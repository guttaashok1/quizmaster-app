{
  "expo": {
    "name": "QuizMaster",
    "slug": "quizmaster",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashokkumargutta.quizmaster",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ashokkumargutta.quizmaster"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#6C63FF"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "QuizMaster needs access to your microphone for voice input.",
          "speechRecognitionPermission": "QuizMaster needs speech recognition to convert your voice to text."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
